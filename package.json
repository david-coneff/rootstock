{
  "name": "rootstock",
  "version": "0.1.0",
  "description": "Cross-platform workbench runtime and capability abstraction layer for browser-based apps that also ship as desktop (Tauri/Electron).",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist",
    "styles"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./web": {
      "types": "./dist/web/index.d.ts",
      "import": "./dist/web/index.js"
    },
    "./tauri": {
      "types": "./dist/tauri/index.d.ts",
      "import": "./dist/tauri/index.js"
    },
    "./styles.css": "./styles/rootstock.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "@tauri-apps/api": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@tauri-apps/api": {
      "optional": true
    }
  }
}
